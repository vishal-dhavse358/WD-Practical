// Set timezone
date_default_timezone_set("Asia/Kolkata");

// Function to get greeting
function getGreeting() {

    $hour = date("H");

    if ($hour < 12) {

        return "Good Morning!";

    } elseif ($hour < 18) {

        return "Good Afternoon!";

    } else {

        return "Good Evening!";

    }

}

