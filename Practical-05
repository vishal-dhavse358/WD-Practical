<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Responsive Bootstrap Page</title>

    <!-- Bootstrap 5 CSS CDN -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body>

    <!-- Navigation Bar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container">

            <a class="navbar-brand" href="#">My Responsive Site</a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link active" href="#">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Features</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Contact</a>
                    </li>

                </ul>

            </div>

        </div>

    </nav>

    <!-- Hero Section -->

    <div class="container mt-4">

        <div class="p-5 mb-4 bg-light rounded-3">

            <div class="container-fluid py-4">

                <h1 class="display-5 fw-bold">Welcome to Bootstrap</h1>

                <p class="fs-5">
                    This is a responsive webpage created using Bootstrap 5 grid system and components.
                </p>

                <button class="btn btn-primary btn-lg">
                    Learn More
                </button>

            </div>

        </div>

    </div>

    <!-- Grid Section -->

    <div class="container">

        <div class="row g-4">

            <div class="col-12 col-md-6 col-lg-4">

                <div class="card shadow">

                    <div class="card-body">

                        <h5 class="card-title">Column 1</h5>

                        <p class="card-text">
                            Full width on small screens, half on medium, one-third on large screens.
                        </p>

                        <a href="#" class="btn btn-outline-primary">
                            Read More
                        </a>

                    </div>

                </div>

            </div>

            <div class="col-12 col-md-6 col-lg-4">

                <div class="card shadow">

                    <div class="card-body">

                        <h5 class="card-title">Column 2</h5>

                        <p class="card-text">
                            Bootstrap grid automatically adjusts layout for different devices.
                        </p>

                        <a href="#" class="btn btn-outline-primary">
                            Read More
                        </a>

                    </div>

                </div>

            </div>

            <div class="col-12 col-md-12 col-lg-4">

                <div class="card shadow">

                    <div class="card-body">

                        <h5 class="card-title">Column 3</h5>

                        <p class="card-text">
                            Using 12-column responsive system for flexible layouts.
                        </p>

                        <a href="#" class="btn btn-outline-primary">
                            Read More
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Footer -->

    <footer class="bg-dark text-white text-center p-3 mt-5">

        <p>© 2026 My Responsive Site | WD Practical</p>

    </footer>

    <!-- Bootstrap JS Bundle -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
