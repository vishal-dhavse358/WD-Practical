<?php

session_start();

if (!isset($_SESSION['values'])) {

    $_SESSION['values'] = [];

}

if ($_SERVER["REQUEST_METHOD"] == "POST" && !empty($_POST['newValue'])) {

    $newValue = $_POST['newValue'];

    $_SESSION['values'][] = $newValue; // Add value to the array

}

?>

