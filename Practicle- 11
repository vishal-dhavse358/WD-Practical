<?php

$inputString = "";

$operation = "";

$result = "";

if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $inputString = $_POST['inputString'] ?? "";

    $operation = $_POST['operation'] ?? "";

    switch ($operation) {

        case 'reverse':

            $result = strrev($inputString);

            break;

        case 'length':

            $result = strlen($inputString);

            break;

        case 'substring':

            $start = intval($_POST['start'] ?? 0);

            $length = intval($_POST['length'] ?? strlen($inputString));

            $result = substr($inputString, $start, $length);

            break;

    }

}

?>

